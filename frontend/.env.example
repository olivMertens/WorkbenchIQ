# =============================================================================
# WorkbenchIQ Frontend Environment Configuration (Sample)
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# Backend API URL (default: http://localhost:8000)
# API_URL=http://localhost:8000

# =============================================================================
# API Authentication
# =============================================================================
# Must match the API_KEY set on the backend. The frontend proxy injects this
# as an X-API-Key header server-side — it is never exposed to the browser.
# If not set, requests are sent without an API key (backend must also be unset).
# API_KEY=your-secret-api-key-at-least-32-characters-long

# =============================================================================
# Frontend Authentication (Optional)
# =============================================================================
# Add users as numbered env vars in format AUTH_USER_N=username:password
# If no AUTH_USER_* vars are set, frontend auth is disabled entirely.
# AUTH_USER_1=admin:changeme
# AUTH_USER_2=reviewer:changeme

# Secret used to sign session tokens (change from default in production!)
# AUTH_SECRET=generate-a-random-64-char-hex-string
